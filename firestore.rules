rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny(['status', 'approvedBy', 'approvedAt', 'subscriptionTier', 'verified']);
    }

    // Public landing pages — anyone can read user profiles for /p/username/
    match /users/{userId} {
      allow read: if true;
    }

    // Admin can read/write everything (GRANDMASTER UID checked in code)
    // Cloud Functions use admin SDK which bypasses rules

    // User link subcollections
    match /users/{userId}/links/{linkId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
